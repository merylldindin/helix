{
  "name": "helix",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "nuxi generate",
    "checks": "concurrently yarn:prettier yarn:stylelint yarn:eslint yarn:types",
    "clean": "nuxi cleanup",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "eslint": "eslint \"app/**/*.{ts,js,vue}\" --no-fix",
    "eslint:fix": "eslint \"app/**/*.{ts,js,vue}\" --fix",
    "prepare": "husky",
    "prettier": "prettier --check --log-level error \"app/**/*.{ts,js,scss,css,vue,json}\"",
    "prettier:fix": "prettier --write \"app/**/*.{ts,js,scss,css,vue,json}\"",
    "serve": "nuxi preview -o",
    "setup": "husky init && rm .husky/pre-commit && chmod ug+x .husky/*",
    "start": "nuxi dev -o",
    "stylelint": "npx stylelint 'app/**/*.{vue,scss}'",
    "stylelint:fix": "npx stylelint 'app/**/*.{vue,scss}' --fix",
    "types": "NODE_OPTIONS='--max-old-space-size=4096' nuxi typecheck"
  },
  "resolutions": {
    "@mdream/rust-wasm32-wasi": "npm:@mdream/rust-darwin-arm64@1.1.0",
    "@nuxt/kit": ">=4.2.2",
    "defu": "^6.1.6",
    "devalue": ">=5.6.2",
    "fast-uri": "^3.1.2",
    "fast-xml-builder": "^1.2.0",
    "fast-xml-parser": "^5.7.1",
    "flatted": "^3.4.2",
    "glob": ">=11.0.0",
    "h3": ">=1.15.9",
    "ip-address": ">=10.0.1",
    "js-yaml": ">=4.1.1",
    "micromatch": ">=4.0.8",
    "nitropack": "^2.13.4",
    "node-forge": "^1.4.0",
    "picomatch": "^2.3.2",
    "qs": ">=6.14.1",
    "semver": ">=7.7.3",
    "srvx": "^0.11.13",
    "tar": ">=7.5.3",
    "tough-cookie": ">=6.0.0",
    "unhead": ">=2.0.0 <3.0.0",
    "vite": "^8.0.5"
  },
  "dependencies": {
    "nuxt-jsonld": "2.2.1",
    "nuxt-swiper": "2.0.1",
    "vue": "3.5.34",
    "vue3-lottie": "3.3.1",
    "vuetify": "4.0.7"
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.1",
    "@commitlint/config-conventional": "21.0.1",
    "@mdi/js": "7.4.47",
    "@mdream/nuxt": "1.1.0",
    "@nuxt/devtools": "3.2.4",
    "@nuxt/eslint": "1.15.2",
    "@nuxt/eslint-config": "1.15.2",
    "@nuxtjs/sitemap": "8.0.15",
    "@playwright/test": "1.60.0",
    "@types/eslint": "9.6.1",
    "@types/node": "25.7.0",
    "@unhead/addons": "2.1.15",
    "@vue/compiler-sfc": "3.5.34",
    "concurrently": "9.2.1",
    "eslint": "10.3.0",
    "eslint-plugin-unicorn": "64.0.0",
    "eslint-plugin-vue": "10.9.1",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.4",
    "nuxt": "4.4.5",
    "nuxt-link-checker": "5.0.10",
    "postcss": "8.5.14",
    "postcss-html": "1.8.1",
    "postcss-scss": "4.0.9",
    "prettier": "3.8.3",
    "prettier-plugin-packagejson": "3.0.2",
    "prettier-plugin-toml": "2.0.6",
    "sass": "1.99.0",
    "serve": "14.2.6",
    "stylelint": "17.11.0",
    "stylelint-config-recommended-scss": "17.0.1",
    "stylelint-config-recommended-vue": "1.6.1",
    "stylelint-config-standard-scss": "17.0.0",
    "stylelint-prettier": "5.0.3",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.3",
    "vite": "8.0.12",
    "vue-eslint-parser": "10.4.0",
    "vue-gtag": "3.7.1",
    "vue-tsc": "3.2.8"
  },
  "packageManager": "yarn@4.14.1",
  "engines": {
    "node": "24.15.0",
    "yarn": "4.14.1"
  }
}
