{
  "name": "helix",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "nuxi generate",
    "checks": "concurrently yarn:prettier yarn:stylelint yarn:eslint yarn:types",
    "clean": "nuxi cleanup",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "eslint": "eslint \"app/**/*.{ts,js,vue}\" --no-fix",
    "eslint:fix": "eslint \"app/**/*.{ts,js,vue}\" --fix",
    "prepare": "husky",
    "prettier": "prettier --check --log-level error \"app/**/*.{ts,js,scss,css,vue,json}\"",
    "prettier:fix": "prettier --write \"app/**/*.{ts,js,scss,css,vue,json}\"",
    "serve": "nuxi preview -o",
    "setup": "husky init && rm .husky/pre-commit && chmod ug+x .husky/*",
    "start": "nuxi dev -o",
    "types": "NODE_OPTIONS='--max-old-space-size=4096' nuxi typecheck"
  },
  "resolutions": {
    "@eslint/config-inspector": "^3.0.0",
    "@mdream/rust-wasm32-wasi": "npm:@mdream/rust-darwin-arm64@1.4.1",
    "@nuxt/kit": ">=4.2.2",
    "defu": "^6.1.6",
    "devalue": ">=5.6.2",
    "esbuild": ">=0.28.1",
    "eslint-plugin-import-x": "^4.16.2",
    "fast-uri": "^4.0.0",
    "fast-xml-builder": "^1.2.0",
    "fast-xml-parser": "^5.9.0",
    "flatted": "^3.4.2",
    "glob": ">=11.0.0",
    "h3": ">=1.15.9",
    "ip-address": ">=10.0.1",
    "js-yaml": ">=4.1.1",
    "micromatch": ">=4.0.8",
    "nitropack": "^2.13.4",
    "node-forge": "^1.4.0",
    "picomatch": "^4.0.0",
    "qs": ">=6.14.1",
    "semver": ">=7.7.3",
    "srvx": "^0.11.13",
    "tar": ">=7.5.3",
    "tough-cookie": ">=6.0.0",
    "unhead": "3.1.4",
    "vite": "8.0.16",
    "vite-plugin-inspect": "^11.4.1",
    "vite-plugin-vue-tracer": "^1.4.0"
  },
  "dependencies": {
    "nuxt-jsonld": "2.2.1",
    "nuxt-swiper": "2.0.2",
    "vue": "3.5.38",
    "vue3-lottie": "3.3.1",
    "vuetify": "4.1.2"
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "@mdi/js": "7.4.47",
    "@mdream/nuxt": "1.4.1",
    "@nuxt/devtools": "3.2.4",
    "@nuxt/eslint": "1.16.0",
    "@nuxt/eslint-config": "1.16.0",
    "@nuxtjs/sitemap": "8.2.1",
    "@playwright/test": "1.61.0",
    "@types/eslint": "9.6.1",
    "@types/node": "25.9.4",
    "@unhead/bundler": "3.1.4",
    "@vue/compiler-sfc": "3.5.38",
    "concurrently": "10.0.3",
    "eslint": "10.5.0",
    "eslint-plugin-unicorn": "67.0.0",
    "eslint-plugin-vue": "10.9.2",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "nuxt": "4.4.8",
    "nuxt-link-checker": "5.1.1",
    "postcss": "8.5.15",
    "postcss-html": "1.8.1",
    "postcss-scss": "4.0.9",
    "prettier": "3.8.4",
    "prettier-plugin-packagejson": "3.0.2",
    "prettier-plugin-toml": "2.0.6",
    "sass": "1.101.0",
    "serve": "14.2.6",
    "stylelint": "17.13.0",
    "stylelint-config-recommended-scss": "17.0.1",
    "stylelint-config-recommended-vue": "1.6.1",
    "stylelint-config-standard-scss": "17.0.0",
    "stylelint-prettier": "5.0.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1",
    "unhead": "3.1.4",
    "vite": "8.0.16",
    "vue-eslint-parser": "10.4.1",
    "vue-gtag": "3.7.1",
    "vue-tsc": "3.3.5"
  },
  "packageManager": "yarn@4.15.0",
  "engines": {
    "node": "24.17.0",
    "yarn": "4.15.0"
  }
}
